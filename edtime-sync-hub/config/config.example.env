# edtime-sync-hub config — salin ke ~/.edtime-sync/config.env

EDTIME_SYNC_HOME=$HOME/.edtime-sync
EDTIME_REPO=$HOME/edtime-sync-hub

GOOGLE_SHEET_ID=your_google_sheet_id_here
EDTIME_DRIVE_FOLDER="Edtime Sync"

EDTIME_FETCH_TIMEOUT=900
EDTIME_FETCH_POLL=30
EDTIME_NOTIFY_ON_COMPLETE=1
EDTIME_MAPPING=$HOME/.edtime-sync/edtime-mapping.json

# Pushcut opsional (instant iPhone trigger)
# PUSHCUT_SECRET=
# DISPATCH_MODE=sheet

KEYCHAIN_SERVICE=edtime-sync
