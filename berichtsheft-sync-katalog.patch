+            if (a.get("blok_name") or "").lower() == needle
+            or needle in (a.get("description_de") or "").lower()
+        ]
+        if not matched:
+            raise HTTPException(404, f"Abteilung tidak ditemukan: {abteilung}")
+        return {"ok": True, "abteilungen": matched}
+    return {"ok": True, "katalog": data}
+
