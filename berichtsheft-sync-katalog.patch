+            aliases = item.get("aliases") or []
+            if item["code"] == code or code in aliases:
+                return {"ok": True, "item": item}
+        raise HTTPException(404, f"Code tidak ditemukan: {code}")
+    if abteilung:
+        needle = abteilung.strip().lower()
