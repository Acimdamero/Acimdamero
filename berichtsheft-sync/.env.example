# Telegram (@BotFather) — jangan commit .env
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=

# API lokal (bot → Mac)
BERICHTSHEFT_API=http://127.0.0.1:8765

# BLok: gunakan Keychain, BUKAN .env
# python3 -m berichtsheft credentials set --service blok

# Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
AI_POLISH_ENABLED=true
AI_VISION_ENABLED=true

# Cursor SDK (Pro) — https://cursor.com/dashboard → Integrations / API Keys
CURSOR_API_KEY=
CURSOR_AGENT_MODEL=composer-2.5
