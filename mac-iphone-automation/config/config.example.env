# Salin ke ~/.automation-hub/config.env lalu isi nilai Anda.
# Jangan commit file config.env yang berisi secret.

# --- Google (Drive + Sheets antrian perintah) ---
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_DRIVE_BACKUP_FOLDER="Automation Hub/Backups"
GOOGLE_DRIVE_LOG_FOLDER="Automation Hub/Logs"

# Path ke service account JSON (Google Cloud Console)
# GOOGLE_APPLICATION_CREDENTIALS=$HOME/.automation-hub/google-service-account.json

# --- Mac Agent ---
AUTOMATION_HUB_HOME=$HOME/.automation-hub
AUTOMATION_REPO=$HOME/automation-hub
POLL_INTERVAL_SECONDS=60

# --- Backup ---
BACKUP_SOURCES="$HOME/Documents|$HOME/Desktop|$HOME/Downloads"
BACKUP_DEST="$HOME/Library/CloudStorage/GoogleDrive-*/Automation Hub/Backups"

# --- Cursor workflow ---
CURSOR_PROJECTS="$HOME/Developer|$HOME/Projects"

# --- Keamanan akun (pilih salah satu atau keduanya) ---
# 1Password CLI vault
OP_VAULT=Private

# Apple Keychain service name untuk token/API key
KEYCHAIN_SERVICE=automation-hub

# --- Pushcut (instant iPhone trigger) ---
# PUSHCUT_SECRET=your_pushcut_server_secret
PUSHCUT_TIMEOUT=nowait
DISPATCH_MODE=pushcut

# --- WhatsApp Business API (Meta Cloud) ---
# WHATSAPP_ACCESS_TOKEN=your_meta_token
# WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# --- WhatsApp backend: meta (resmi) | waha (self-hosted personal) ---
WHATSAPP_BACKEND=waha

# --- WAHA (WhatsApp HTTP API) ---
WAHA_BASE_URL=http://localhost:3000
WAHA_SESSION=default
WAHA_API_KEY=automation-hub-test-key

# --- edtime sync (iPhone → Cursor) ---
EDTIME_DRIVE_FOLDER="Automation Hub/Edtime"
EDTIME_FETCH_TIMEOUT=900
EDTIME_FETCH_POLL=30
EDTIME_NOTIFY_ON_COMPLETE=1
# EDTIME_MAPPING=$HOME/.automation-hub/edtime-mapping.json
# EDTIME_WEBHOOK_URL=  # alternatif; prefer Keychain via edtime-save-credentials.sh

# --- Docker autostart (Mac login) ---
DOCKER_AUTOSTART=1
DOCKER_START_TIMEOUT=300
# AUTOMATION_REPO=$HOME/Acimdamero/mac-iphone-automation
# WAHA_COMPOSE_FILE=$AUTOMATION_REPO/docker/docker-compose.waha.yml
