# Salin ke ~/.automation-hub/secrets.env lalu isi SEKALI.
# Jalankan: bash run-edtime-agentic.sh
# File ini TIDAK boleh di-commit dengan nilai asli.

# --- Wajib untuk sync edtime ---
GOOGLE_SHEET_ID=
HUB_WEBHOOK_URL=

# --- Opsional ---
EDTIME_USER=
PUSHCUT_API_KEY=
PUSHCUT_SERVER=
WAHA_API_KEY=automation-hub-test-key

# --- Jadwal otomatis (cron-style di Mac) ---
EDTIME_AUTO_SYNC=1
EDTIME_SYNC_CRON_HOURS=7,19
EDTIME_FETCH_TIMEOUT=900

# --- Mode agentic ---
AUTONOMOUS=1
SKIP_WAHA=0
SKIP_IPHONE_DISPATCH=0
